# ─────────────────────────────────────────────────────────────────────────────
# my-service environment variables
#
# Copy this file to .env and fill in the values.
# NEVER commit .env to git. NEVER put secrets in config/default.json.
# ─────────────────────────────────────────────────────────────────────────────

# ── API authentication ────────────────────────────────────────────────────────
# Set this to require X-API-Key: <value> on all API requests.
# Leave empty to allow unauthenticated access (local dev only).
API_KEY=

# ── Telegram bot ──────────────────────────────────────────────────────────────
# 1. Create a bot with @BotFather on Telegram → copy the token here.
# 2. Get your chat ID: message @userinfobot or @getidsbot.
# 3. Set TELEGRAM_ALLOWED_CHAT_IDS — leave empty ONLY for testing (insecure).
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=   # e.g. 123456789,987654321

# ── WhatsApp (Baileys direct integration) ──────────────────────────────────────
# Uses direct WhatsApp multi-device API (like NanoClaw).
# No Twilio account needed. Free. Just set this to enable.
# Session will be stored in data/whatsapp-sessions/ after first QR scan.
WHATSAPP_ENABLED=false         # Set to true to enable WhatsApp
